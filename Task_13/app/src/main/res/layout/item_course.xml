<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_stroke"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="0dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <View
            android:id="@+id/accentBar"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_accent_bar"
            android:layout_marginStart="14dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvCourseName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/accentBar"
            app:layout_constraintEnd_toStartOf="@id/btnEdit" />

        <TextView
            android:id="@+id/tvCourseCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_chip_dark"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintTop_toBottomOf="@id/tvCourseName"
            app:layout_constraintStart_toEndOf="@id/accentBar" />

        <TextView
            android:id="@+id/tvCredits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_chip_outline"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/tvCourseName"
            app:layout_constraintStart_toEndOf="@id/tvCourseCode" />

        <TextView
            android:id="@+id/tvInstructor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:drawablePadding="5dp"
            android:drawableStart="@drawable/ic_person"
            app:layout_constraintTop_toBottomOf="@id/tvCourseCode"
            app:layout_constraintStart_toEndOf="@id/accentBar"
            app:layout_constraintEnd_toStartOf="@id/btnEdit" />

        <TextView
            android:id="@+id/tvSchedule"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:drawablePadding="5dp"
            android:drawableStart="@drawable/ic_schedule"
            app:layout_constraintTop_toBottomOf="@id/tvInstructor"
            app:layout_constraintStart_toEndOf="@id/accentBar"
            app:layout_constraintEnd_toStartOf="@id/btnEdit"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_edit"
            android:background="@drawable/bg_icon_circle"
            android:contentDescription="Edit"
            android:padding="9dp"
            app:tint="@color/black_primary"
            app:layout_constraintEnd_toStartOf="@id/btnDelete"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_delete"
            android:background="@drawable/bg_delete_circle"
            android:contentDescription="Delete"
            android:padding="9dp"
            app:tint="@color/red_delete"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>